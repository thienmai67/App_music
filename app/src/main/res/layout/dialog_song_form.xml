<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"> <androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="10dp"
    app:contentPadding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎶 Thêm Bài Hát Mới 🎶"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/edtDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên bài hát"
            android:inputType="textCapSentences"
            android:textColorHint="#9E9E9E"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_form" />

        <EditText
            android:id="@+id/edtDialogArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên ca sĩ"
            android:inputType="textCapWords"
            android:textColorHint="#9E9E9E"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_form" />

        <EditText
            android:id="@+id/edtDialogPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Link nhạc mp3 "
            android:inputType="textUri"
            android:textColorHint="#9E9E9E"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_form" />

        <EditText
            android:id="@+id/edtDialogImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Link ảnh bìa "
            android:inputType="textUri"
            android:textColorHint="#9E9E9E"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_form" />

        <EditText
            android:id="@+id/edtDialogLyrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Lời bài hát "
            android:inputType="textMultiLine"
            android:gravity="top"
            android:lines="4"
            android:textColorHint="#9E9E9E"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_form" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(*) Các trường bắt buộc nhập"
            android:textSize="12sp"
            android:textColor="#FF5252"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
</ScrollView>